# ── Motorsport Analytics — Variables de Entorno ──────────────────────────────
# Copia este archivo como .env y ajusta los valores para tu entorno.

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Directorio para archivos temporales (se crea automáticamente si no existe)
# TEMP_DIR=/tmp/motorsport-analytics

# Host y puerto del servidor
API_HOST=0.0.0.0
API_PORT=8000

# Activar recarga automática (solo en desarrollo)
API_RELOAD=false

# Tamaño máximo de archivo subido en MB (default: 100)
MAX_UPLOAD_MB=100

# URL de la API para el frontend (usada por Vite)
VITE_API_URL=http://localhost:8000/api
